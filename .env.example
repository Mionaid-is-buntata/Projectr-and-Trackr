# Projctr — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. Shell environment always takes precedence over .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
DATABASE_PATH=./projctr.db

# ── Huntr ─────────────────────────────────────────────────────────────────────
# Path to the directory containing scored Huntr job JSON files.
HUNTR_JOBS_PATH=/path/to/huntr-data/jobs/scored

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# HTTP URL of your ChromaDB instance.
CHROMADB_URL=http://localhost:8000
# Name of the CV/jobs collection in ChromaDB.
CHROMADB_COLLECTION=your-cv-collection-name

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
# Collection for pain-point embeddings.
QDRANT_COLLECTION=projctr
# Collection for description embeddings (fuzzy dedup).
QDRANT_DESCRIPTION_COLLECTION=projctr_descriptions

# ── Embedding / LLM (Ollama) ──────────────────────────────────────────────────
# Full URL to the Ollama embeddings endpoint.
EMBEDDING_ENDPOINT=http://localhost:11434/api/embeddings
# Base URL for the Ollama LLM endpoint (used when extraction.llm.enabled = true).
LLM_ENDPOINT=http://localhost:11434

# ── Deployment (used by Makefile deploy target) ───────────────────────────────
DEPLOY_USER=your-user
DEPLOY_HOST=your-host-or-ip
DEPLOY_DIR=/opt/projctr
